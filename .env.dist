# =============================================================================
# .env.dist — hand-roll reference for the webtrees-docker stack
# =============================================================================
#
# The installer wizard's production flow writes a minimal `.env` with three
# always-present keys (WEBTREES_VERSION, PHP_VERSION, WEBTREES_NGINX_VERSION)
# plus APP_PORT in standalone mode. The dev-mode wizard writes a richer set
# (COMPOSE_FILE, MARIADB_*, LOCAL_USER_*, etc.) sourced from env.dev.j2.
# Anything either wizard skips falls back to compose.yaml / entrypoint
# defaults at runtime.
#
# This file is your hand-roll reference if you skip the wizard. Copy to
# `.env`, fill in what your deployment needs. Most keys ship with a usable
# default; the keys that ship empty and must be set before the stack
# starts are MARIADB_ROOT_PASSWORD and MARIADB_PASSWORD, plus DEV_DOMAIN
# (when behind Traefik or using the dev install path) and MARIADB_HOST
# (when using compose.external.yaml's external-network mode).
#
# Per-variable docblocks below note scope when it is not obvious from the
# variable name — e.g. "(dev-only)" for variables that only matter when
# the development overlay is active.
# =============================================================================

###########
# General #
###########

# The PHP version to use for all containers.
# Supported versions: 7.4, 8.0, 8.1, 8.2, 8.3, 8.4
# Note: e.g. Webtrees v2.2.0 requires PHP 8.2 or higher
# Default: 8.3
PHP_VERSION=8.3

# Webtrees release version bundled into the image.
# Used at image build time to download the matching release archive.
# In dev mode (host bind-mount of ./app), the bundled copy is ignored.
# Default: 2.2.6
WEBTREES_VERSION=2.2.6

# Specifies the PHP configuration mode.
# Options:
#   - development: Enables error reporting, disables opcache for easier debugging
#   - production: Optimizes for performance, enables opcache, disables error reporting
# Default: development (runtime fallback when unset: production)
ENVIRONMENT=development

# Docker compose project name.
# This prevents conflicts with other Docker projects by ensuring unique container names.
# Example: If set to "webtrees", containers will be named "webtrees-nginx", "webtrees-db", etc.
# Default: webtrees
COMPOSE_PROJECT_NAME=webtrees

# HTTPS enforcement setting.
# Options:
#   - TRUE: Forces HTTPS by redirecting all HTTP requests to HTTPS
#   - FALSE: Allows both HTTP and HTTPS connections
# Note: The entrypoint enforces HTTPS only when the value matches TRUE
# case-insensitively (TRUE, True, true all qualify); any other value
# (including unset/empty) leaves HTTPS enforcement disabled.
# For production environments, TRUE is strongly recommended for security.
# Default: TRUE (runtime fallback when unset: disabled)
ENFORCE_HTTPS=TRUE

# Extension of the X-Forwarded-Proto trust gate's CIDR set.
# Comma-separated CIDR list (IPv4 with /0..32, IPv6 with /0..128); leave
# empty to use only the baked conservative defaults (127.0.0.0/8,
# ::1/128, 172.16.0.0/12, fc00::/7). Wildcards (0.0.0.0/0, ::/0) are
# refused. Operators with a reverse proxy outside the default ranges
# (e.g. Traefik on 10.42.0.0/16) set this so the proxy's
# X-Forwarded-Proto: https header is honoured. See docs/customizing.md.
# Default: empty
NGINX_TRUSTED_PROXIES=

# Directory where the webtrees application will be installed.
# (dev-only — only consumed by buildbox-side scripts; the dev overlay
# bind-mounts ./app directly.)
# This directory is mounted into the buildbox container and contains all
# application code. The application is available within Buildbox
# ("make bash") under the directory /app.
# Default: ./app (relative to project root)
APP_DIR=./app

# Directory where webtrees stores user-uploaded media.
# (Consumed by compose.development.yaml's bind-mount fallback and by
# compose.external.yaml's required bind-mount; wizard-rendered standalone
# production stacks use a named Docker volume and ignore this.) When set,
# the directory is bind-mounted into the container at
# /var/www/html/data/media. config.ini.php and cache live inside the app
# volume — only media is meant to be persisted on the host or backed up
# separately.
# Default: ./persistent/media (relative to project root)
MEDIA_DIR=./persistent/media

# Reverse-proxy hostname — Traefik routes by Host header to this value,
# and the dev install path writes it into config.ini.php's base_url.
# Do not include http:// or https:// prefixes.
# Example: webtrees.example.com
# Note: required when compose.traefik.yaml is in the chain OR when the dev
# install path (`make install` / `make apply-config`) runs; ignore for a
# standalone wizard install with no reverse proxy.
DEV_DOMAIN=

################
# Docker stack #
################

# This section configures which Docker Compose files to use for different environments.
# The installer wizard sets this automatically based on the proxy mode you pick.
# For further customisations, create a compose.override.yaml in the same directory.

# Available configuration options:
#
# 1. Production environment, standalone:
#    - Uses the pre-built image from the registry
#    - compose.publish.yaml maps nginx to APP_PORT on the host
#    - Add :compose.modules.yaml to bind-mount ./modules into modules_v4/
#COMPOSE_FILE=compose.yaml:compose.publish.yaml

# 2. Production environment behind Traefik:
#    - Same image, Traefik routes by Host header — no host port published
#    - Add :compose.modules.yaml to bind-mount ./modules into modules_v4/
#COMPOSE_FILE=compose.yaml:compose.traefik.yaml

# 3. Development environment (without reverse proxy):
#    - Includes development tools, buildbox containers and phpMyAdmin
#    - compose.publish.yaml maps nginx directly to the host
#    - compose.external.yaml allows using an external MariaDB
#COMPOSE_FILE=compose.yaml:compose.pma.yaml:compose.development.yaml:compose.publish.yaml:compose.external.yaml

# 4. Development environment with Traefik reverse proxy:
#    - Includes all development features and phpMyAdmin
#    - Integrates with Traefik for domain-based access
#    - Add :compose.publish.yaml to ALSO expose nginx on APP_PORT
#COMPOSE_FILE=compose.yaml:compose.pma.yaml:compose.development.yaml:compose.traefik.yaml:compose.external.yaml

# Set by the dev-mode installer wizard. The production wizard renders a
# self-contained compose.yaml and does not write this key. If you're
# hand-rolling, uncomment one of the four pre-set lines above or populate
# this with your own compose chain.
COMPOSE_FILE=

###############
# Host Ports  #
###############

# Configure the host ports used to access the services when no reverse proxy
# (like Traefik) is used. APP_PORT is consumed by compose.publish.yaml, the
# overlay that maps nginx to the host. PMA_PORT is consumed by the dev
# overlay's pma override.

# Webtrees application port (host -> container:80)
#APP_PORT=50010

# phpMyAdmin port (host -> container:80)
#PMA_PORT=50011

#################################
# User information for buildbox #
#################################

# These settings control file ownership across the stack:
#   - In dev mode, the buildbox container runs as this UID/GID so files
#     it writes match the host user.
#   - When LOCAL_USER_ID is set, the production entrypoint remaps the
#     in-container www-data to that UID/GID so any host bind-mount stays
#     readable as the host user without a root chown. Wizard-rendered
#     production stacks use named Docker volumes and typically leave
#     LOCAL_USER_ID unset; hand-roll stacks that bind-mount media or data
#     from the host (e.g. on a consumer NAS) usually need to set it.

# User ID (UID) for the buildbox user.
# This should match your host system user ID to avoid permission issues.
# How to find your UID:
#   - Linux/macOS: Run "id -u" in terminal
#   - Windows with WSL: Run "id -u" in WSL terminal
# Example: 1000 (common default for first user on Linux systems)
LOCAL_USER_ID=

# Username for the buildbox user.
# This is used for display purposes and in container logs.
# Requirements:
#   - Must not contain dots or special characters
#   - Should be lowercase
# Example: developer
LOCAL_USER_NAME=

# Group ID (GID) for file access.
# This should be set to the web server group ID to ensure proper file permissions.
# Common GIDs:
#   - 82 for Alpine Linux (nginx)
#   - 33 for Debian/Ubuntu (www-data)
# How to find a group ID:
#   - Linux/macOS: Run "getent group www-data" or "id -g"
# Default: 82
LOCAL_GROUP_ID=82

# Group name for file access.
# This should match the web server group name.
# Common values:
#   - www-data (Debian/Ubuntu)
#   - nginx (Alpine)
#   - apache (CentOS/RHEL)
# Default: www-data
LOCAL_GROUP_NAME=www-data

##################
# Image versions #
##################

# nginx image revision (own tag track, decoupled from webtrees/PHP versions).
# Schema: <nginx-base>-r<config-revision>, e.g. 1.30-r1. When configs under
# rootfs/etc/nginx/ change, bump config-revision (and dev/nginx-version.json).
# Default: 1.30-r1
WEBTREES_NGINX_VERSION=1.30-r1

# nginx build-arg consumed by compose.development.yaml when rebuilding the
# nginx image from source. (dev-only — production stacks pull the prebuilt
# image and ignore this.) Keep in lockstep with WEBTREES_NGINX_VERSION's
# revision component.
# Default: 1
NGINX_CONFIG_REVISION=1

#################
# Docker Server #
#################

# Docker registry namespace from which images are pulled. Substituted into
# `${DOCKER_SERVER}/webtrees/...` references in compose.yaml. The published
# images on ghcr.io/magicsunday are public, so no credentials are required
# locally. For an out-of-band publish, run `gh workflow run build.yml`.
# Default: ghcr.io/magicsunday
DOCKER_SERVER=ghcr.io/magicsunday

###########
# MariaDB #
###########

# Database configuration settings for the Webtrees application.
# These settings are used by both the database container and the application
# to establish connections and set up the initial database.

# Root password for the MariaDB database.
# This is used for administrative access to the database.
# Security requirements:
#   - Must be at least 8 characters long
#   - Should include a mix of letters, numbers, and special characters
#   - Should not be reused from other services
# Note: This password is only used within the container and is not exposed externally
# unless you explicitly configure external access.
MARIADB_ROOT_PASSWORD=

# Database host address.
# Options:
#   - For the built-in database container: "db" (the service name in docker-compose)
#   - For an external database: IP address or hostname of your database server
# When using compose.external.yaml with an external database, this is also
# the name of the external Docker network where your database is running.
# Note: leave empty to fall back to the bundled-container default ("db").
# Set explicitly when using compose.external.yaml so the external-network
# name resolves correctly.
MARIADB_HOST=

# Database port number.
# The standard port for MariaDB/MySQL is 3306.
# Only change this if your database runs on a non-standard port.
# Default: 3306
MARIADB_PORT=3306

# Name of the database to create for Webtrees.
# This database will be automatically created during container initialization
# if it doesn't already exist.
# Default: webtrees
MARIADB_DATABASE=webtrees

# Database user for Webtrees application.
# This user will be granted full access to the Webtrees database only.
# It's recommended to use a dedicated user for the application rather than root.
# Default: webtrees
MARIADB_USER=webtrees

# Password for the Webtrees database user.
# Security requirements:
#   - Must be at least 8 characters long
#   - Should include a mix of letters, numbers, and special characters
#   - Should not be the same as the root password
# This password will be used by the application to connect to the database.
MARIADB_PASSWORD=

# Initial database usage setting.
# Determines whether the dev-mode install should assume an existing,
# already-initialised Webtrees database and write an initial config file.
# Options:
#   - 1: Use an existing database; install-application.sh writes config.ini.php based on .env
#   - 0: Do not use an existing database; skip initial configuration (install via UI or later)
# Note:
#   - The dev-mode installer wizard asks for this and writes USE_EXISTING_DB into the dev .env.
#   - If this variable is omitted, scripts default to 1 (use existing DB).
# Default (recommended for migrations): 1
#USE_EXISTING_DB=1

########
# Mail #
########

# Webtrees' built-in SMTP transport (#43). The entrypoint writes these
# into the site_setting database table at boot when WT_SMTP_HOST is set.
# Symfony Mailer handles auth + STARTTLS + connection pooling. Used for
# every Core mail surface: registration verification, password reset,
# contact form, watch lists, manager-approval notices.
#
# When WT_SMTP_HOST is unset the entrypoint leaves the site_setting
# rows alone — operators who configured SMTP via the Control panel UI
# keep their config across restarts.

# SMTP relay hostname. Empty → site_setting rows are left untouched
# (operators who configured SMTP via the UI keep their config).
# Setting this auto-flips SMTP_ACTIVE=external in the database.
WT_SMTP_HOST=

# SMTP relay port. Default: 25 (plaintext / opportunistic STARTTLS),
# 465 (SMTPS / implicit TLS), 587 (submission with STARTTLS).
WT_SMTP_PORT=

# HELO/EHLO identity. Defaults to the container hostname when empty;
# operators with strict relays should set this to a forward-resolvable
# name (e.g. mailer.example.org).
WT_SMTP_HELO=

# Visible name in the From: header webtrees sends with.
# Example: "webtrees genealogy"
WT_SMTP_FROM_NAME=

# SMTP auth credentials. Setting WT_SMTP_AUTH_USER auto-flips
# SMTP_AUTH=1 in the database; clearing it sets SMTP_AUTH=0 so an old
# auth config from a previous boot doesn't survive against a new
# auth-less relay.
WT_SMTP_AUTH_USER=

# Plaintext password — prefer WT_SMTP_AUTH_PASSWORD_FILE for the
# Docker-secrets pattern (file path; expand_file_secrets resolves it
# at boot, then unsets the *_FILE variant).
WT_SMTP_AUTH_PASSWORD=
WT_SMTP_AUTH_PASSWORD_FILE=

# Transport encryption:
#   - ssl  → SMTPS / implicit TLS (port 465)
#   - tls  → STARTTLS (port 25 or 587)
#   - none → cleartext (don't use for credentialed relays)
# Webtrees' EmailService compares strictly to "ssl"; anything else
# falls through to STARTTLS-if-available. Default: none
WT_SMTP_SSL=

################
# PHP settings #
################

# These settings control PHP behavior in the application.
# Adjusting these values can improve performance, allow larger uploads,
# and handle more complex genealogy data.

# Maximum script execution time in seconds.
# This limits how long a PHP script can run before it's terminated.
# Recommended values:
#   - 30-60 seconds for most operations
#   - 120-300 seconds for importing large GEDCOM files
#   - Set higher if you have very large family trees or complex reports
# Default: 30
PHP_MAX_EXECUTION_TIME=30

# PHP memory limit.
# This controls the maximum amount of memory a PHP script can use.
# Recommended values:
#   - 128M for small to medium sites
#   - 256M for medium to large sites
#   - 512M or more for very large family trees
# Note: Setting this too high can impact server performance
# Default: 256M (runtime fallback when unset: 128M)
PHP_MEMORY_LIMIT=256M

# Maximum number of input variables.
# This limits how many form fields and GET/POST variables can be processed.
# Increase this value if you encounter errors when:
#   - Working with large forms
#   - Using complex search filters
#   - Importing data with many fields
# Default: 1000
PHP_MAX_INPUT_VARS=1000

# Maximum file upload size.
# This limits the size of individual files that can be uploaded.
# Recommended values:
#   - 32M for basic document uploads
#   - 128M for high-resolution scans, large GEDCOM files or video files
# Default: 128M
PHP_UPLOAD_MAX_FILESIZE=128M

# Maximum POST request size.
# This limits the total size of all data in a POST request, including file uploads.
# This value must be equal to or larger than PHP_UPLOAD_MAX_FILESIZE.
# Default: 128M
PHP_POST_MAX_SIZE=128M

##############
# phpMyAdmin #
##############

# Configuration for the phpMyAdmin container.
# phpMyAdmin provides a web interface for managing the MariaDB database.

# Maximum upload size for SQL files in phpMyAdmin.
# This controls how large SQL files can be when importing databases.
# Recommended values:
#   - 32M for most databases
#   - 64M or more for very large databases
# Note: This is separate from the PHP upload limits and only affects phpMyAdmin
# Default: 32M
UPLOAD_LIMIT=32M

##########################
# Webtrees Configuration #
##########################

# Application-specific settings for Webtrees.
# These settings control how Webtrees interacts with the database
# and handles URLs.

# Database table prefix.
# This prefix is added to all database table names created by Webtrees.
# Benefits of using a prefix:
#   - Allows multiple Webtrees installations to share a database
#   - Makes it easier to identify Webtrees tables in the database
#   - Helps prevent table name conflicts with other applications
# Default: wt_
WEBTREES_TABLE_PREFIX=wt_

# URL rewriting setting.
# This controls whether Webtrees uses clean URLs without "index.php" in the path.
# Options:
#   - 0: Disable URL rewriting (URLs will include index.php)
#   - 1: Enable URL rewriting (URLs will be shorter and more user-friendly)
# Note: Enabling URL rewriting requires proper server configuration (mod_rewrite for Apache)
# Default: 0
WEBTREES_REWRITE_URLS=0
