# Webtrees end-user shortcuts.
# Generated by the installer (v{{ installer_version }}); safe to edit,
# but `./install --force` overwrites on the next run.
#
# Every target is a thin docker compose wrapper. Run `make` without
# arguments (or `make help`) for a one-screen overview.

SHELL = /bin/bash

.SILENT:

# Do not print "Entering directory ..."
MAKEFLAGS += --no-print-directory

.DEFAULT_GOAL := help

# Standard terminal colors. `ifneq ($(TERM),)` keeps non-TTY callers
# (CI logs, piped scripts) clean by leaving the FBOLD/FRESET vars empty
# instead of leaking literal escape sequences. Mirrors the dev
# Makefile's `Make/helper/colors.mk` convention so operator-facing
# output looks the same in the install dir and the dev checkout.
ifneq ($(TERM),)
	FBOLD   := $(shell tput bold)
	FRESET  := $(shell tput sgr0)
	FRED    := $(shell tput setaf 1)
	FGREEN  := $(shell tput setaf 2)
	FYELLOW := $(shell tput setaf 3)
	FBLUE   := $(shell tput setaf 4)
endif

# Auto-detect docker compose. `docker compose` (v2 plugin) is the
# documented requirement — the install bootstrap rejects v1 via the
# Compose-version prereq check — but the auto-detect block survives a
# manual `docker-compose` symlink for power users who keep v1 around
# for unrelated stacks.
COMPOSE_BIN := $(shell \
	if command -v docker >/dev/null 2>&1 && docker compose version >/dev/null 2>&1; then \
		echo "docker compose"; \
	elif command -v docker-compose >/dev/null 2>&1; then \
		echo "docker-compose"; \
	else \
		echo "echo 'Error: Docker Compose v2 not available' && exit 1"; \
	fi)

.PHONY: .logo help up down restart logs pull shell cli backup restore switch-enforce-https switch-https switch-http

# Match the dev Makefile's ASCII logo. The heredoc-style printf keeps
# the file self-contained — the install dir has no `Make/helper/`
# layout, so embedding the banner here removes that dependency.
.logo:
	@printf '%s\n' \
		' .____                         .__                                .___               ____.' \
		' |   _|   _____ _____     ____ |__| ____   ________ __  ____    __| _/____  ___.__. |_   |' \
		' |  |    /     \\__  \   / ___\|  |/ ___\ /  ___/  |  \/    \  / __ |\__  \<   |  |   |  |' \
		' |  |   |  Y Y  \/ __ \_/ /_/  >  \  \___ \___ \|  |  /   |  \/ /_/ | / __ \\___  |   |  |' \
		' |  |_  |__|_|  (____  /\___  /|__|\___  >____  >____/|___|  /\____ |(____  / ____|  _|  |' \
		' |____|       \/     \//_____/         \/     \/           \/      \/     \/\/      |____|'

help: .logo  ## Show this help.
	@echo -e "\n${FYELLOW}Webtrees end-user shortcuts${FRESET}\n"
	@awk 'BEGIN {FS = ":.*## "} /^[a-zA-Z0-9_-]+:.*## / { \
		gsub(/ \.logo/, "", $$1); \
		printf "  ${FGREEN}%-22s${FRESET} %s\n", $$1, $$2 \
	}' $(MAKEFILE_LIST)
	@echo ""

up: .logo  ## Start the stack detached.
	@echo -e "${FBLUE}▶ start stack${FRESET}"
	$(COMPOSE_BIN) up -d

down: .logo  ## Stop the stack (named volumes survive).
	@echo -e "${FBLUE}▶ stop stack${FRESET}"
	$(COMPOSE_BIN) down

restart: .logo  ## Restart all services.
	@echo -e "${FBLUE}▶ restart stack${FRESET}"
	$(COMPOSE_BIN) restart

logs: .logo  ## Tail all service logs (Ctrl-C to detach).
	@echo -e "${FBLUE}▶ follow logs${FRESET}"
	$(COMPOSE_BIN) logs -f

pull: .logo  ## Refresh images to the pinned tags.
	@echo -e "${FBLUE}▶ refresh images${FRESET}"
	$(COMPOSE_BIN) pull

shell: .logo  ## Drop into the phpfpm container as www-data.
	@echo -e "${FBLUE}▶ phpfpm shell${FRESET}"
	$(COMPOSE_BIN) exec --user www-data phpfpm /bin/sh

cli: .logo  ## Run webtrees' php CLI inside phpfpm. Usage: make cli ARGS='<args>'
	@if [ -z "$$ARGS" ]; then \
		echo "${FRED}usage:${FRESET} make cli ARGS='<webtrees-cli-args>'" >&2; \
		exit 1; \
	fi
	@echo -e "${FBLUE}▶ webtrees-cli $$ARGS${FRESET}"
	$(COMPOSE_BIN) exec --user www-data phpfpm php /var/www/html/index.php $$ARGS

# backup writes a gzipped mariadb-dump to stdout so the operator can pipe
# anywhere (file, ssh, s3 cli, …) without the Makefile dictating layout.
# The password lives in /secrets/mariadb_password inside the db container
# (compose passes MARIADB_PASSWORD_FILE, not a plain MARIADB_PASSWORD env),
# so the wrapper reads it from the file at exec time. Stack must be running.
#
# `set -o pipefail` propagates a failing mariadb-dump (auth refused, db
# missing, …) through the gzip stage — otherwise gzip's exit-0 masks the
# upstream failure and `make backup > out.sql.gz` writes a zero-row
# archive with rc=0, which is the worst kind of silent data loss.
backup: ## Dump the database to stdout (gzipped). Usage: make backup > backup-$$(date -u +%Y%m%d).sql.gz
	@set -o pipefail; $(COMPOSE_BIN) exec -T db sh -c \
		'mariadb-dump --user="$$MARIADB_USER" --password="$$(cat "$$MARIADB_PASSWORD_FILE")" "$$MARIADB_DATABASE"' \
		| gzip

# restore reads a backup file (.sql.gz produced by `make backup`) and
# pipes it into the db container. Existing rows are overwritten by the
# dump's INSERTs; truncate/drop happens only if the dump itself emits
# those statements. Stack must be running.
restore: .logo  ## Restore a database dump produced by 'make backup'. Usage: make restore FILE=backup.sql.gz
	@if [ -z "$$FILE" ]; then \
		echo "${FRED}usage:${FRESET} make restore FILE=<path/to/backup.sql.gz>" >&2; \
		exit 1; \
	fi
	@if [ ! -f "$$FILE" ]; then \
		echo "${FRED}restore:${FRESET} file not found: $$FILE" >&2; \
		exit 1; \
	fi
	@echo -e "${FBLUE}▶ restore from $$FILE${FRESET}"
	@gunzip -c "$$FILE" | $(COMPOSE_BIN) exec -T db sh -c \
		'mariadb --user="$$MARIADB_USER" --password="$$(cat "$$MARIADB_PASSWORD_FILE")" "$$MARIADB_DATABASE"'

# switch-enforce-https flips ENFORCE_HTTPS in .env, then restarts the
# two services that read it (nginx for the 301 redirect, phpfpm for the
# HSTS / cookie-secure flags webtrees emits). Volumes survive the
# restart so user data + config.ini.php + media stay untouched.
# Idempotent — running it twice with the same VALUE is a no-op.
# switch-https / switch-http are thin aliases pinning VALUE to TRUE /
# FALSE.
#
# The sed rewrite preserves the line position and handles three
# starting shapes (`ENFORCE_HTTPS=TRUE`, `ENFORCE_HTTPS=FALSE`, missing
# from the file). On the missing-from-file path we append rather than
# fail — the entrypoint already defaults to disabled when the var is
# absent, so appending makes the new value durable across restarts.
switch-enforce-https: .logo  ## Flip ENFORCE_HTTPS to VALUE (TRUE|FALSE) and restart nginx + phpfpm.
	@if [ "$(VALUE)" != "TRUE" ] && [ "$(VALUE)" != "FALSE" ]; then \
		echo "${FRED}switch-enforce-https:${FRESET} VALUE must be TRUE or FALSE (got '$(VALUE)')" >&2; \
		exit 1; \
	fi
	@if [ ! -f .env ]; then \
		echo "${FRED}switch-enforce-https:${FRESET} .env not found; run from your install directory" >&2; \
		exit 1; \
	fi
	@if grep -qE '^ENFORCE_HTTPS=' .env; then \
		sed -i -E 's|^ENFORCE_HTTPS=.*|ENFORCE_HTTPS=$(VALUE)|' .env; \
	else \
		echo "ENFORCE_HTTPS=$(VALUE)" >> .env; \
	fi
	@echo -e "${FBLUE}▶ ENFORCE_HTTPS=$(VALUE); restarting nginx + phpfpm${FRESET}"
	$(COMPOSE_BIN) up -d --force-recreate --no-deps nginx phpfpm

switch-https: ## Flip ENFORCE_HTTPS=TRUE and restart nginx + phpfpm.
	@$(MAKE) switch-enforce-https VALUE=TRUE

switch-http: ## Flip ENFORCE_HTTPS=FALSE and restart nginx + phpfpm.
	@$(MAKE) switch-enforce-https VALUE=FALSE
