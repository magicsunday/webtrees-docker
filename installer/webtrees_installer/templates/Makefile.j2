# Webtrees end-user shortcuts.
# Generated by the installer (v{{ installer_version }}); safe to edit,
# but `./install --force` overwrites on the next run.
#
# Every target is a thin docker compose wrapper. Run `make` without
# arguments (or `make help`) for a one-screen overview.

.PHONY: help up down restart logs pull shell cli backup restore

.DEFAULT_GOAL := help

help: ## Show this help.
	@echo "Webtrees end-user shortcuts"
	@echo
	@echo "  make up                    Start the stack in the background"
	@echo "  make down                  Stop the stack (volumes survive)"
	@echo "  make restart               Restart all services"
	@echo "  make logs                  Tail all service logs (Ctrl-C to detach)"
	@echo "  make pull                  Refresh images to the pinned tags"
	@echo "  make shell                 Drop into the phpfpm container as www-data"
	@echo "  make cli ARGS='<args>'     Run webtrees' php CLI inside phpfpm"
	@echo "  make backup > backup.sql.gz"
	@echo "                             Dump the database to stdout (gzipped)"
	@echo "  make restore FILE=<path>   Restore a database dump produced by 'make backup'"

up: ## Start the stack detached.
	docker compose up -d

down: ## Stop the stack (named volumes survive).
	docker compose down

restart: ## Restart all services.
	docker compose restart

logs: ## Tail all service logs.
	docker compose logs -f

pull: ## Refresh images to the pinned tags.
	docker compose pull

shell: ## Drop into the phpfpm container as www-data.
	docker compose exec --user www-data phpfpm /bin/sh

cli: ## Run webtrees' php CLI inside phpfpm. Usage: make cli ARGS='admin list'
	@if [ -z "$$ARGS" ]; then \
		echo "usage: make cli ARGS='<webtrees-cli-args>'" >&2; \
		exit 1; \
	fi
	docker compose exec --user www-data phpfpm php /var/www/html/index.php $$ARGS

# backup writes a gzipped mariadb-dump to stdout so the operator can pipe
# anywhere (file, ssh, s3 cli, …) without the Makefile dictating layout.
# The password lives in /secrets/mariadb_password inside the db container
# (compose passes MARIADB_PASSWORD_FILE, not a plain MARIADB_PASSWORD env),
# so the wrapper reads it from the file at exec time. Stack must be running.
#
# `set -o pipefail` propagates a failing mariadb-dump (auth refused, db
# missing, …) through the gzip stage — otherwise gzip's exit-0 masks the
# upstream failure and `make backup > out.sql.gz` writes a zero-row
# archive with rc=0, which is the worst kind of silent data loss.
backup: ## Dump the database to stdout (gzipped). Usage: make backup > backup-$(date -u +%Y%m%d).sql.gz
	@set -o pipefail; docker compose exec -T db sh -c \
		'mariadb-dump --user="$$MARIADB_USER" --password="$$(cat "$$MARIADB_PASSWORD_FILE")" "$$MARIADB_DATABASE"' \
		| gzip

# restore reads a backup file (.sql.gz produced by `make backup`) and
# pipes it into the db container. Existing rows are overwritten by the
# dump's INSERTs; truncate/drop happens only if the dump itself emits
# those statements. Stack must be running.
restore: ## Restore a database dump produced by 'make backup'. Usage: make restore FILE=backup.sql.gz
	@if [ -z "$$FILE" ]; then \
		echo "usage: make restore FILE=<path/to/backup.sql.gz>" >&2; \
		exit 1; \
	fi
	@if [ ! -f "$$FILE" ]; then \
		echo "restore: file not found: $$FILE" >&2; \
		exit 1; \
	fi
	@gunzip -c "$$FILE" | docker compose exec -T db sh -c \
		'mariadb --user="$$MARIADB_USER" --password="$$(cat "$$MARIADB_PASSWORD_FILE")" "$$MARIADB_DATABASE"'
