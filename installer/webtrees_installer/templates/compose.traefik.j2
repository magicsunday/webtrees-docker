{# Traefik (reverse-proxy) compose layout. -#}
{% import "_compose_macros.j2" as m -%}
volumes:
    secrets:
{%- if db_type != "sqlite" %}
    database:
{%- endif %}
    app:
    media:

networks:
    default:
    traefik:
        external: true
        name: {{ traefik_network }}

services:
    init:
        image: {{ alpine_image }}
        restart: "no"
        volumes:
            - secrets:/secrets
        command:
            - sh
            - -ec
            - |
                umask 077
                for name in {% if db_type != "sqlite" %}mariadb_root_password mariadb_password{% endif %}{% if admin_bootstrap %}{% if db_type != "sqlite" %} {% endif %}wt_admin_password{% endif %}; do
                  if [ ! -s "/secrets/$$name" ]; then
                    head -c 24 /dev/urandom | od -An -tx1 | tr -d ' \n' > "/secrets/$$name"
                  fi
                done
                # find-with-exec instead of `chmod /secrets/*` so an
                # empty /secrets (db_type=sqlite + admin_bootstrap=False
                # → zero secrets to generate) does not trigger glob-
                # expansion failure under `sh -ec`. find returns 0 on
                # empty input; the `/secrets/*` glob would leak the
                # unexpanded literal to chmod and fail rc=1.
                find /secrets -mindepth 1 -type f -exec chmod 444 {} +
{%- if db_type != "sqlite" %}

    db:
        image: mariadb:11.8
        depends_on:
            init:
                condition: service_completed_successfully
        restart: unless-stopped
        environment:
            MARIADB_ROOT_PASSWORD_FILE: /secrets/mariadb_root_password
            MARIADB_USER: webtrees
            MARIADB_PASSWORD_FILE: /secrets/mariadb_password
            MARIADB_DATABASE: webtrees
        volumes:
            - secrets:/secrets:ro
            - database:/var/lib/mysql
        healthcheck:
            test: ["CMD", "healthcheck.sh", "--connect", "--innodb_initialized"]
            interval: 10s
            timeout: 5s
            retries: 5
            start_period: 10s
{%- endif %}

    phpfpm:
        image: ghcr.io/magicsunday/webtrees-php{% if edition == "full" %}-full{% endif %}:{{ webtrees_version }}-php{{ php_version }}
        depends_on:
{%- if db_type == "sqlite" %}
            init:
                condition: service_completed_successfully
{%- else %}
            db:
                condition: service_healthy
{%- endif %}
        restart: unless-stopped
        environment:
            {#- Traefik mode never supports `--use-external-db` (the
                wizard rejects the combination); the hard-coded False
                keeps the macro signature symmetric with the standalone
                caller while making the constraint visible. #}
            {{ m.phpfpm_environment(
                use_external_db=False,
                db_type=db_type,
                webtrees_version=webtrees_version,
                pretty_urls=pretty_urls,
                admin_bootstrap=admin_bootstrap,
                admin_user=admin_user,
                admin_email=admin_email,
            ) | indent(12) }}
        {{ m.phpfpm_healthcheck() | indent(8) }}
        volumes:
            - secrets:/secrets:ro
            - app:/var/www/html
            - media:/var/www/html/data/media

    nginx:
        image: ghcr.io/magicsunday/webtrees-nginx:{{ nginx_tag }}
        depends_on:
            phpfpm:
                condition: service_healthy
        restart: unless-stopped
        environment:
            ENFORCE_HTTPS: "${ENFORCE_HTTPS:-FALSE}"
        networks:
            - default
            - traefik
        labels:
            traefik.enable: "true"
            traefik.docker.network: "{{ traefik_network }}"
            traefik.http.routers.webtrees.rule: "Host(`{{ domain }}`)"
            traefik.http.routers.webtrees.entrypoints: "websecure"
            traefik.http.routers.webtrees.tls: "true"
            traefik.http.services.webtrees.loadbalancer.server.port: "80"
        {{ m.nginx_healthcheck() | indent(8) }}
        volumes:
            - app:/var/www/html:ro
            - media:/var/www/html/data/media:ro
