{# Standalone (no reverse proxy) compose layout. -#}
volumes:
    secrets:
{%- if reuse_volumes_project %}
        # #41 BYOD: --reuse-volumes also externalises `secrets:` so the
        # init container reads the original install's mariadb_password
        # rather than generating a fresh random one that no longer
        # matches the user/grant inside the reused database volume.
        external: true
        name: {{ reuse_volumes_project }}_secrets
{%- endif %}
{%- if not use_external_db %}
    database:
{%- if reuse_volumes_project %}
        # #41 BYOD: --reuse-volumes pins this stack's `database:` reference
        # to the named volume from another compose project (typically a
        # prior webtrees install). Compose treats `external: true` as
        # "do not create, expect existing".
        external: true
        name: {{ reuse_volumes_project }}_database
{%- elif db_data_path %}
        # #41 BYOD: --db-data-path bind-mounts MariaDB's /var/lib/mysql to
        # a host path. mariadb:11.8 expects the directory empty on first
        # boot, or pre-populated by a prior compatible-version install.
        driver: local
        driver_opts:
            type: none
            device: {{ db_data_path }}
            o: bind
{%- endif %}
{%- endif %}
    app:
    media:
{%- if reuse_volumes_project %}
        external: true
        name: {{ reuse_volumes_project }}_media
{%- elif media_path %}
        # #41 BYOD: --media-path bind-mounts webtrees' data/media to a host
        # path. The php-fpm container's runtime user must be able to
        # read+write — chown the host path to that uid if you hit
        # permission errors.
        driver: local
        driver_opts:
            type: none
            device: {{ media_path }}
            o: bind
{%- endif %}

services:
    init:
        image: {{ alpine_image }}
        restart: "no"
        volumes:
            - secrets:/secrets
        command:
            - sh
            - -ec
            - |
                umask 077
                for name in {% if not use_external_db %}mariadb_root_password mariadb_password{% endif %}{% if admin_bootstrap %}{% if not use_external_db %} {% endif %}wt_admin_password{% endif %}; do
                  if [ ! -s "/secrets/$$name" ]; then
                    head -c 24 /dev/urandom | od -An -tx1 | tr -d ' \n' > "/secrets/$$name"
                  fi
                done
                # `find` returns 0 on empty / missing inputs; the matching
                # idiom for "chmod 444 every file we just may have written"
                # without swallowing a real chmod failure on a populated
                # /secrets directory (FS readonly, ownership conflict,
                # SELinux denial).
                find /secrets -mindepth 1 -type f -exec chmod 444 {} +
{%- if not use_external_db %}

    db:
        image: mariadb:11.8
        depends_on:
            init:
                condition: service_completed_successfully
        restart: unless-stopped
        environment:
            MARIADB_ROOT_PASSWORD_FILE: /secrets/mariadb_root_password
            MARIADB_USER: webtrees
            MARIADB_PASSWORD_FILE: /secrets/mariadb_password
            MARIADB_DATABASE: webtrees
        volumes:
            - secrets:/secrets:ro
            - database:/var/lib/mysql
        healthcheck:
            test: ["CMD", "healthcheck.sh", "--connect", "--innodb_initialized"]
            interval: 10s
            timeout: 5s
            retries: 5
            start_period: 10s
{%- endif %}

    phpfpm:
        image: ghcr.io/magicsunday/webtrees/php{% if edition == "full" %}-full{% endif %}:{{ webtrees_version }}-php{{ php_version }}
        depends_on:
{%- if use_external_db %}
            init:
                condition: service_completed_successfully
{%- else %}
            db:
                condition: service_healthy
{%- endif %}
        restart: unless-stopped
        environment:
            ENVIRONMENT: production
            ENFORCE_HTTPS: "${ENFORCE_HTTPS:-FALSE}"
            WEBTREES_VERSION: "{{ webtrees_version }}"
            WEBTREES_AUTO_SEED: "true"
{%- if use_external_db %}
            MARIADB_HOST: "${EXTERNAL_DB_HOST}"
            MARIADB_PORT: "${EXTERNAL_DB_PORT:-3306}"
            MARIADB_USER: "${EXTERNAL_DB_USER:-webtrees}"
            MARIADB_PASSWORD_FILE: /secrets/external_db_password
            MARIADB_DATABASE: "${EXTERNAL_DB_NAME:-webtrees}"
{%- else %}
            MARIADB_HOST: db
            MARIADB_USER: webtrees
            MARIADB_PASSWORD_FILE: /secrets/mariadb_password
            MARIADB_DATABASE: webtrees
{%- endif %}
            WEBTREES_REWRITE_URLS: "{% if pretty_urls %}1{% else %}0{% endif %}"
{%- if admin_bootstrap %}
            WT_ADMIN_USER: "{{ admin_user }}"
            WT_ADMIN_EMAIL: "{{ admin_email }}"
            WT_ADMIN_PASSWORD_FILE: /secrets/wt_admin_password
{%- endif %}
        healthcheck:
            test: ["CMD-SHELL", "pgrep php-fpm > /dev/null || exit 1"]
            interval: 5s
            timeout: 3s
            retries: 3
            # 45s rather than 5s: the entrypoint runs the seed step, the
            # config-ini write, the schema migration, and (when enabled)
            # the admin-bootstrap chain BEFORE php-fpm itself is exec'd.
            # On a CI runner with a cold image cache that sequence can
            # eat 20-30s; 5s left no headroom and compose-up `Waiting`
            # tripped to `unhealthy` while php-fpm was still finishing
            # the bootstrap. 45s + (3 × 5s) = 60s total grace.
            start_period: 45s
        volumes:
            - secrets:/secrets:ro
            - app:/var/www/html
            - media:/var/www/html/data/media
{%- if use_external_db %}
            # ${VAR:?msg} aborts `docker compose up` when EXTERNAL_DB_PASSWORD_FILE
            # is unset or empty, instead of bind-mounting an anonymous volume
            # at /secrets/external_db_password and falling through to a
            # passwordless mariadb auth attempt 30 s later.
            - "${EXTERNAL_DB_PASSWORD_FILE:?EXTERNAL_DB_PASSWORD_FILE must be set in .env}:/secrets/external_db_password:ro"
{%- endif %}

    nginx:
        image: ghcr.io/magicsunday/webtrees/nginx:{{ nginx_tag }}
        depends_on:
            phpfpm:
                condition: service_healthy
        restart: unless-stopped
        environment:
            ENFORCE_HTTPS: "${ENFORCE_HTTPS:-FALSE}"
        ports:
            - "${APP_PORT:-{{ app_port }}}:80"
        healthcheck:
            # Probe the login page rather than `/` because `/` returns 404
            # by design when no tree exists yet (operator imports the GEDCOM
            # post-install). The login route resolves as soon as
            # config.ini.php, the schema, and any admin user exist.
            # X-Forwarded-Proto: https tells nginx the upstream already
            # terminated TLS, bypassing the enforce-https redirect (see
            # rootfs/etc/nginx/conf.d/default.conf $isHttps logic). Keeps
            # the healthcheck honest regardless of ENFORCE_HTTPS value.
            test: ["CMD-SHELL", "curl -sf -H 'X-Forwarded-Proto: https' 'http://localhost/index.php?route=/login' -o /dev/null || exit 1"]
            interval: 10s
            timeout: 5s
            retries: 3
            # The probe requires config.ini.php + DB schema + (optional)
            # admin user — first-boot bootstrap on slow disks (NAS, cold
            # composer cache) can exceed 30s. 60s covers WEBTREES_AUTO_SEED
            # cleanly without dragging the docker-compose up wait time.
            start_period: 60s
        volumes:
            - app:/var/www/html:ro
            - media:/var/www/html/data/media:ro
