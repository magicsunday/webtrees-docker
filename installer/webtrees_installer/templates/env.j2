# Generated by webtrees-installer {{ installer_version }} on {{ generated_at }}.
# Edit at will; the wizard does not read this file on subsequent runs.

WEBTREES_VERSION={{ webtrees_version }}
PHP_VERSION={{ php_version }}
WEBTREES_NGINX_VERSION={{ nginx_tag }}

# HTTPS enforcement (#35, #45). Flip with `make switch-https` /
# `make switch-http` from the install dir, OR edit this line and run
# `docker compose up -d --force-recreate --no-deps nginx phpfpm`.
# `compose.yaml` reads ${ENFORCE_HTTPS:-FALSE} so the runtime fallback
# when this key is unset is `FALSE`.
ENFORCE_HTTPS={% if enforce_https %}TRUE{% else %}FALSE{% endif %}

{%- if proxy_mode == "standalone" %}

# Override the host port if you need to publish on a different port.
APP_PORT={{ app_port }}
{%- endif %}
