{
    "name": "magicsunday/webtrees-base",
    "description": "Docker-based development and deployment environment for webtrees.",
    "license": "MIT",
    "authors": [
        {
            "name": "Rico Sonntag",
            "email": "mail@ricosonntag.de",
            "role": "Developer",
            "homepage": "https://www.ricosonntag.de/"
        }
    ],
    "config": {
        "preferred-install": {
            "*": "dist"
        },
        "allow-plugins": {
            "cweagans/composer-patches": true
        },
        "sort-packages": true
    },
    "require": {
        "fisharebest/webtrees": "~2.2.0",
        "cweagans/composer-patches": "^1.7"
    },
    "extra": {
        "patches": {
            "fisharebest/webtrees": {
                "Disable the in-app upgrade prompt (bundled image is immutable)": "patches/disable-upgrade-prompt.patch",
                "Add VendorModuleService for composer-installed modules": "patches/add-vendor-module-service.patch"
            }
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "../scripts/update-application.sh",
            "../scripts/update-languages.sh"
        ]
    }
}
