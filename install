#!/usr/bin/env bash
# Webtrees self-host installer launcher.
#
# Usage:
#   curl -fsSL https://raw.githubusercontent.com/magicsunday/webtrees-docker/main/install | bash
#   ./install [--non-interactive --edition core --proxy standalone --port 8080 ...]
#
# Mounts the current directory as /work inside the installer image and exposes
# the docker socket so the wizard can probe ports and bring the stack up.
# Assumes Linux Docker Engine with a daemon socket at /var/run/docker.sock;
# Docker Desktop on macOS/Windows needs the equivalent context to be the
# default.

set -o errexit -o nounset -o pipefail

INSTALLER_IMAGE="${INSTALLER_IMAGE:-ghcr.io/magicsunday/webtrees/installer:latest}"

if ! command -v docker >/dev/null 2>&1; then
    echo "docker is not on PATH. Install Docker Engine first: https://docs.docker.com/engine/install/" >&2
    exit 1
fi

# Sanity-warn when there's no socket the bind-mount can reach. Rootless
# Docker keeps the socket under $XDG_RUNTIME_DIR/docker.sock, and tcp /
# ssh contexts surface via $DOCKER_HOST and don't need a unix socket at all.
if [[ -z "${DOCKER_HOST:-}" \
      && ! -S /var/run/docker.sock \
      && ! -S "${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/docker.sock" ]]; then
    echo "warning: no docker socket found at /var/run/docker.sock or \$XDG_RUNTIME_DIR/docker.sock; set DOCKER_HOST or check your daemon" >&2
fi

# Allocate a TTY only when stdin and stdout are terminals — `curl ... | bash`
# pipes stdin through a fifo, so `-it` would die with 'the input device is
# not a TTY' and the wizard's non-interactive mode (--non-interactive) is
# what the user is expected to combine with the curl one-liner.
tty_flags=()
if [[ -t 0 && -t 1 ]]; then
    tty_flags=(-it)
fi

# Compose derives the project name from the cwd basename if no
# compose.yaml `name:` key and no COMPOSE_PROJECT_NAME env are set. The
# wizard runs inside a container whose cwd is /work, so its idea of
# "cwd basename" would be "work", not the user's actual install
# directory. Export the normalised host-cwd basename so the wizard's
# secrets pre-seed lines up with the volume compose will mount at
# runtime. Honour an existing COMPOSE_PROJECT_NAME if the user already
# set one, but still normalise it through the same filter so the wizard
# and compose see the same value.
if [ -n "${COMPOSE_PROJECT_NAME:-}" ]; then
    COMPOSE_PROJECT_NAME=$(printf '%s' "$COMPOSE_PROJECT_NAME" | tr '[:upper:]' '[:lower:]' | tr -cd 'a-z0-9_-')
else
    COMPOSE_PROJECT_NAME=$(basename "$(pwd)" | tr '[:upper:]' '[:lower:]' | tr -cd 'a-z0-9_-')
fi
if [ -z "$COMPOSE_PROJECT_NAME" ]; then
    echo "compose project name is empty after normalisation; rename your install directory or set COMPOSE_PROJECT_NAME to an alphanumeric value" >&2
    exit 1
fi
export COMPOSE_PROJECT_NAME

# Inject host UID/name before user args so --mode dev gets the real values.
# (Inside the container os.geteuid() returns 0; the wizard cannot see them.
# Standalone mode ignores both flags. User-supplied values still override.)
installer_args=(
    --local-user-id "$(id -u)"
    --local-user-name "$(id -un)"
    "$@"
)

# WORK_DIR carries the host's current directory into the wizard. Dev mode
# needs it because compose.development.yaml's bind-mount device-paths use
# ${WORK_DIR:-${PWD}}: inside the installer container ${PWD} resolves to
# /work, which does not exist on the host docker daemon and breaks the
# mount. The launcher reads the path from the host shell where ${PWD} is
# the real cwd, then the wizard writes WORK_DIR=<host-path> into .env.
#
# --pull=always forces a freshness check against the registry on every
# launch. The installer image ships as a rolling :latest tag; docker's
# default --pull=missing would otherwise reuse whatever copy the user
# pulled the first time and silently shadow later bug-fix releases.
exec docker run --rm --pull=always "${tty_flags[@]}" \
    -e WORK_DIR="$PWD" \
    -e COMPOSE_PROJECT_NAME \
    -v "$PWD:/work" \
    -v /var/run/docker.sock:/var/run/docker.sock \
    "$INSTALLER_IMAGE" "${installer_args[@]}"
