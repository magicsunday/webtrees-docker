#!/usr/bin/env bash
# Webtrees self-host upgrade launcher.
#
# Usage:
#   curl -fsSL https://raw.githubusercontent.com/magicsunday/webtrees-docker/main/upgrade | bash
#   curl -fsSL .../upgrade | bash -s -- --port 8443        # override defaults
#   ./upgrade [--edition core ...]
#
# Stops the running stack, drops the <project>_app volume so the new image
# can re-seed it, then re-runs install with --force so the wizard rewrites
# compose.yaml + .env and brings the stack up against the latest pinned
# release. The <project>_database and <project>_media volumes survive the
# upgrade. The <project> prefix mirrors compose's own project-name
# derivation when neither compose.yaml nor .env pins it.

set -o errexit -o nounset -o pipefail

INSTALLER_REMOTE="${INSTALLER_REMOTE:-https://raw.githubusercontent.com/magicsunday/webtrees-docker/main/install}"

if ! command -v docker >/dev/null 2>&1; then
    echo "docker is not on PATH. Install Docker Engine first: https://docs.docker.com/engine/install/" >&2
    exit 1
fi

# `docker compose down` needs a compose.yaml in the working directory. If
# the user piped curl into bash from the wrong cwd (typically $HOME), the
# error would be cryptic — fail loud with a path hint instead.
if [ ! -f compose.yaml ] && [ ! -f docker-compose.yaml ]; then
    echo "no compose.yaml in $(pwd); cd into your webtrees stack directory first" >&2
    exit 1
fi

# No args → use the README quickstart defaults so the typical
# `curl ... | bash` invocation just works. Anything passed on the command
# line overrides; --force is always appended so the wizard does not stop
# at the override prompt.
if [ "$#" -eq 0 ]; then
    set -- --non-interactive --no-admin --edition full --proxy standalone --port 8080
fi

echo "→ Stopping existing stack..."
docker compose down

# Mirror docker compose v2's project-name normalization: honour
# COMPOSE_PROJECT_NAME if set, else lowercase the cwd basename and
# strip every char that isn't [a-z0-9_-]. A naive `basename` would
# desync the volume names we touch from the volumes compose actually
# mounts whenever the cwd has uppercase letters or special chars.
if [ -n "${COMPOSE_PROJECT_NAME:-}" ]; then
    project=$(printf '%s' "$COMPOSE_PROJECT_NAME" | tr '[:upper:]' '[:lower:]' | tr -cd 'a-z0-9_-')
else
    project=$(basename "$(pwd)" | tr '[:upper:]' '[:lower:]' | tr -cd 'a-z0-9_-')
fi
echo "→ Removing ${project}_app volume so the new image re-seeds it..."
docker volume rm -f "${project}_app"

echo "→ Re-running install with --force..."
curl -fsSL "$INSTALLER_REMOTE" | bash -s -- "$@" --force
