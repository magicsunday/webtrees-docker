###############################################################################
# Production-mode test environment
#
# Copy to .env.prod-test (gitignored), edit if needed, then drive it with
# `make prod-up` / `make prod-down` / `make prod-config`. The stack runs in
# the COMPOSE_PROJECT_NAME below, isolated from the regular dev `webtrees`
# project — separate volumes, separate containers, separate networks.
###############################################################################

# Isolated project namespace so containers and volumes do not clash with dev.
COMPOSE_PROJECT_NAME=webtrees-prod-test

# Minimal production chain: base + nginx port publishing. No dev overlay,
# no buildbox, no Traefik.
COMPOSE_FILE=compose.yaml:compose.publish.yaml

# Host port (default avoids clashing with 50010 if dev is still running)
APP_PORT=58080

# Image to test
PHP_VERSION=8.5
WEBTREES_VERSION=2.2.6
DOCKER_SERVER=ghcr.io/magicsunday

# Application
ENVIRONMENT=production
ENFORCE_HTTPS=FALSE

# Test database credentials — change before using outside this scratch stack
MARIADB_ROOT_PASSWORD=test_root
MARIADB_DATABASE=webtrees
MARIADB_USER=webtrees
MARIADB_PASSWORD=test_password
MARIADB_HOST=db
MARIADB_PORT=3306

# PHP — entrypoint defaults assume these are set
PHP_MAX_EXECUTION_TIME=30
PHP_MAX_INPUT_VARS=1000
PHP_MEMORY_LIMIT=256M
PHP_POST_MAX_SIZE=128M
PHP_UPLOAD_MAX_FILESIZE=128M

# Mail — leave empty unless you actually send mail from the test
MAIL_DOMAIN=example.org
MAIL_HOST=
MAIL_SMTP=
