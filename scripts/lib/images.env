# =============================================================================
# Source-able image pins for scripts/ helpers.
# =============================================================================
#
# Counterpart to Make/images.mk so shell scripts can `source` the same
# pin set without parsing make. `ci-images-lockstep` asserts the values
# here match Make/images.mk byte-for-byte; a bump in either file fails
# CI until both are updated.
#
# Usage in a script:
#   # shellcheck source=scripts/lib/images.env
#   source "$(dirname "$0")/lib/images.env"
#   docker run --rm "$CI_IMAGE_JQ" ...

CI_IMAGE_PYTHON="python:3.13-slim"
CI_IMAGE_JQ="ghcr.io/jqlang/jq:latest"
CI_IMAGE_HADOLINT="hadolint/hadolint:latest"
CI_IMAGE_SHELLCHK="koalaman/shellcheck:stable"
CI_IMAGE_YAMLLINT="cytopia/yamllint:latest"
